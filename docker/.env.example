# ═══════════════════════════════════════════════════
# متغيرات البيئة — istxbot Docker
# انسخ هذا الملف إلى docker/.env واملأ القيم
# ═══════════════════════════════════════════════════

# ── بوت تيليجرام الرئيسي ──
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_id
BOT_WEBHOOK_URL=https://istx.io/api/bot/webhook

# ── بوت التطوير ──
DEV_BOT_TOKEN=your_dev_bot_token
DEEPSEEK_API_KEY=sk-your_key_here
ADMIN_CHAT_ID=your_telegram_id
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# ── أمان المشرف ──
ADMIN_PASSWORD_HASH=sha256_hash_of_admin_password
BOT_API_KEY=your_secret_api_key

# ── قاعدة البيانات والتحميلات ──
DB_PATH=/app/data/bot_data.db
DOWNLOAD_DIR=/app/downloads

# ── منافذ الويب ──
WEB_HOST=0.0.0.0
WEB_PORT=8080

# ── البريد (للاسترجاع والاشتراكات) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# ── إعدادات ووردبريس (اختياري) ──
WP_DB_PATH=/app/data/wordpress.db
SUPPORT_PHONE=966XXXXXXXXX

# ── مسار المشرف ──
ADMIN_PATH=control
